{
	"name": "formzilla",
	"version": "4.0.7",
	"description": "Fastify plugin for parsing multipart/form data",
	"type": "module",
	"main": "index.js",
	"files": [
		"!**/*.ts",
		"**/*.js",
		"**/*.d.ts",
		"!test"
	],
	"scripts": {
		"build": "tsc",
		"pretest": "tsc",
		"test": "ava test/**/*.js"
	},
	"author": "FlameWolf",
	"repository": {
		"url": "https://github.com/FlameWolf/formzilla"
	},
	"license": "ISC",
	"dependencies": {
		"busboy": "^1.6.0"
	},
	"keywords": [
		"fastify",
		"multipart",
		"multipart/form-data",
		"form-data",
		"form",
		"content-type-parser",
		"contentTypeParser",
		"plugin",
		"busboy",
		"file",
		"upload",
		"json-schema",
		"jsonSchema",
		"@fastify/swagger"
	],
	"devDependencies": {
		"@types/busboy": "^1.5.4",
		"@types/node": "^25.5.0",
		"ava": "^7.0.0",
		"fastify": "^5.8.4",
		"form-data": "^4.0.5",
		"typescript": "^6.0.2"
	},
	"ava": {
		"files": [
			"!**/setup*.js"
		]
	}
}